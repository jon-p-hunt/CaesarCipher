<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CaesarCipher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/accent_red</item>
        <item name="colorPrimaryVariant">@color/accent_red</item>
        <item name="colorOnPrimary">@color/text_light</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/slate</item>
        <item name="colorSecondaryVariant">@color/slate</item>
        <item name="colorOnSecondary">@color/text_light</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_dark</item>
        <item name="colorOnBackground">@color/text_light</item>
        <item name="colorOnSurface">@color/text_light</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
